# ═══════════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO PARA DESPLIEGUE DE BASE DE DATOS
# ═══════════════════════════════════════════════════════════════
# 
# Instrucciones:
# 1. Copia este archivo a .env
# 2. Reemplaza los valores de ejemplo con los reales
# 3. NO subas el archivo .env al repositorio (está en .gitignore)
#

# ───────────────────────────────────────────────────────────────
# BASE DE DATOS REMOTA (Producción)
# ───────────────────────────────────────────────────────────────
REMOTE_DB_HOST=206.62.139.11
REMOTE_DB_PORT=5432
REMOTE_DB_NAME=parroquia_db
REMOTE_DB_USER=parroquia_user
REMOTE_DB_PASSWORD=TU_CONTRASEÑA_AQUI

# ───────────────────────────────────────────────────────────────
# SERVIDOR SSH (Opcional - para scripts automatizados)
# ───────────────────────────────────────────────────────────────
SSH_HOST=206.62.139.11
SSH_USER=ubuntu
SSH_PORT=22
# SSH_KEY_PATH=/ruta/a/tu/clave.pem (opcional)

# ───────────────────────────────────────────────────────────────
# CONFIGURACIÓN DE LA APLICACIÓN
# ───────────────────────────────────────────────────────────────
APP_DIR=/home/ubuntu/parroquia-api
PM2_APP_NAME=parroquia-api
