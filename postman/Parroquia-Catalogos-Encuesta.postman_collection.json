			"name": "Autenticación",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const jsonData = pm.response.json();",
									"",
									"pm.test('Response has accessToken', function () {",
									"    pm.expect(jsonData.data).to.have.property('accessToken');",
									"});",
									"",
									"if (jsonData && jsonData.data && jsonData.data.accessToken) {",
									"    pm.environment.set(\"access_token\", jsonData.data.accessToken);",
									"    console.log('✅ Token guardado exitosamente');",
									"    console.log('Token preview:', jsonData.data.accessToken.substring(0, 30) + '...');",
									"    console.log('Variable set:', pm.collectionVariables.get('access_token').substring(0, 30) + '...');",
									"} else {",
									"    console.error('❌ No se pudo extraer el token');",
									"    console.log('Response:', JSON.stringify(jsonData, null, 2));",
									"}"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"correo_electronico\": \"admin@parroquia.com\",\n  \"contrasena\": \"Admin123!\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						}
					},
					"response": []
				}
			]
