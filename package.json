{
  "name": "parroquia-api",
  "version": "1.0.0",
  "description": "API REST para gestión de parroquia",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "dev:https": "HTTPS=true nodemon src/app.js",
    "setup:complete": "node setup-complete-system.js",
    "setup:testing": "npm run setup:complete",
    "setup:production": "npm run setup:complete",
    "db:check": "node checkDatabase.js",
    "db:seed:all": "npx sequelize-cli db:seed:all",
    "db:seed:roles": "npx sequelize-cli db:seed --seed 20240101000008-roles.cjs",
    "db:seed:roles:enhanced": "node scripts/seedRoles.js",
    "db:seed:config": "npx sequelize-cli db:seed --seed 20240101000001-tipos-identificacion.cjs --seed 20240101000002-estados-civiles.cjs --seed 20240101000003-tipos-vivienda.cjs --seed 20240101000004-sistemas-acueducto.cjs --seed 20240101000005-tipos-aguas-residuales.cjs --seed 20240101000006-tipos-disposicion-basura.cjs --seed 20240101000007-sexos.cjs --seed 20240101000008-roles.cjs",
    "db:seed:undo": "npx sequelize-cli db:seed:undo:all",
    "db:sync:complete": "node setup-complete-database.js",
    "roles:verify": "node scripts/verificarRoles.js",
    "roles:list": "node scripts/verificarRoles.js listar",
    "admin:create": "node scripts/createAdminUser.js",
    "pm2:start": "npx pm2 start ecosystem.config.cjs",
    "pm2:stop": "npx pm2 stop ecosystem.config.cjs",
    "pm2:restart": "npx pm2 restart ecosystem.config.cjs",
    "pm2:logs": "npx pm2 logs",
    "pm2:status": "npx pm2 status",
    "docker:dev": "docker-compose up --build",
    "docker:db": "docker-compose up postgres -d",
    "docker:down": "docker-compose down",
    "docs:generate": "node generate-copilot-instructions.js"
  },
  "keywords": [
    "node",
    "express",
    "api",
    "rest"
  ],
  "author": "amph7019@gmail.com",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.11.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.2",
    "chart.js": "^4.5.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.2.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.2.1",
    "morgan": "^1.10.0",
    "node-fetch": "^3.3.2",
    "node-forge": "^1.3.1",
    "nodemailer": "^6.9.8",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "sequelize": "^6.37.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.17.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.31.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "pm2": "^5.3.0",
    "sequelize-cli": "^6.6.3",
    "supertest": "^6.3.3"
  },
  "eslintConfig": {
    "extends": "eslint:recommended"
  }
}
