{
  "name": "parroquia-api",
  "version": "1.0.0",
  "description": "API REST para gestión de parroquia",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "db:sync": "node syncDatabase.js",
    "db:sync:alter": "node syncDatabaseAlter.js",
    "db:sync:force": "node syncDatabaseForce.js",
    "db:reset": "node reset-database.js",
    "db:fix:structure": "node fix-database-structure.js",
    "db:fix:municipios": "node fix-municipios-structure.js",
    "db:check": "node checkDatabase.js",
    "db:seed:config": "node runSeeders.js",
    "db:seed:veredas": "node seed-veredas.js",
    "db:seed:complete": "npm run db:seed:config && node seed-parroquias.js && node seed-geographic-data.js && node seed-veredas.js",
    "setup:database": "node setup-complete-database.js",
    "setup:fresh": "npm run setup:database",
    "admin:create": "node scripts/createAdminUser.js",
    "admin:create:default": "node create-default-admin.js",
    "admin:clean": "node check-and-clean-users.js",
    "pm2:start": "npx pm2 start ecosystem.config.cjs",
    "pm2:stop": "npx pm2 stop ecosystem.config.cjs",
    "pm2:restart": "npx pm2 restart ecosystem.config.cjs",
    "pm2:logs": "npx pm2 logs",
    "pm2:status": "npx pm2 status",
    "docker:dev": "docker-compose up --build",
    "docker:db": "docker-compose up postgres -d",
    "docker:down": "docker-compose down",
    "docs:generate": "node generate-copilot-instructions.js"
  },
  "keywords": [
    "node",
    "express",
    "api",
    "rest"
  ],
  "author": "amph7019@gmail.com",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.11.0",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.2",
    "chart.js": "^4.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-validator": "^7.2.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-fetch": "^3.3.2",
    "node-forge": "^1.3.1",
    "nodemailer": "^6.9.8",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "sequelize": "^6.37.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.17.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.31.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "pm2": "^5.3.0",
    "sequelize-cli": "^6.6.3",
    "supertest": "^6.3.3"
  },
  "eslintConfig": {
    "extends": "eslint:recommended"
  }
}